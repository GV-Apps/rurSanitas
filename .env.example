# ── Copia este archivo como .env.prod en la carpeta docker/ para producción ──
# NUNCA subas .env.prod al repositorio.

# Cadena de conexión PostgreSQL (RDS en producción)
DATABASE_URL=postgresql://rur_user:CHANGE_ME@your-rds-endpoint.rds.amazonaws.com:5432/rur_prod

# Clave secreta para las sesiones (genera con: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=CHANGE_ME_32_hex_chars

# Modo debug (false en producción)
DEBUG=false

# Prefijo de subpath (dejar vacío si la app ocupa la raíz del dominio)
# Ejemplo para midominio.com/rur:  ROOT_PATH=/rur
ROOT_PATH=

# Gunicorn workers (recomendado: 2 * núcleos + 1)
GUNICORN_WORKERS=3

# Contraseña del administrador en el primer despliegue (solo aplica si la BD está vacía)
# Si no se define, se genera una aleatoria y se imprime en el log de arranque.
ADMIN_INITIAL_PASSWORD=CHANGE_ME_on_first_deploy

# Correo del superior inmediato por defecto en carga masiva de usuarios
DEFAULT_SUPERIOR_INMEDIATO=superior.responsable@epssanitas.com

# Imagen ECR (para docker-compose.prod.yml)
ECR_IMAGE=123456789012.dkr.ecr.us-east-1.amazonaws.com/rur-app:latest
