# .env.prod.example — Plantilla de configuración de producción
#
# INSTRUCCIONES:
#   1. Copia este archivo en el servidor como:  docker/.env.prod
#   2. Rellena todos los valores reales
#   3. NUNCA subas .env.prod a Git (está en .gitignore)
#   4. Permisos recomendados en el servidor: chmod 600 docker/.env.prod

# ── Base de datos (PostgreSQL externo) ────────────────────────────────────────
# Formato: postgresql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_DB
DATABASE_URL=postgresql://usuario:contraseña@host-db:5432/nombre_db

# ── Seguridad ─────────────────────────────────────────────────────────────────
# Genera una clave segura con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-por-una-clave-secreta-larga-y-aleatoria

# ── Servidor ──────────────────────────────────────────────────────────────────
DEBUG=false

# Número de workers de Gunicorn (recomendado: 2 × núcleos CPU + 1)
GUNICORN_WORKERS=3

# ── Seed inicial (solo aplica si la BD está vacía en el primer arranque) ──────
# Si no se define ADMIN_INITIAL_PASSWORD, se genera una aleatoria en los logs.
ADMIN_INITIAL_PASSWORD=CHANGE_ME_on_first_deploy

# Correo del superior inmediato por defecto en carga masiva de usuarios
DEFAULT_SUPERIOR_INMEDIATO=superior.responsable@epssanitas.com
